{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KidGameMaker",
  "version": "0.1.0",
  "identifier": "com.docdamage.kidgamemaker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KidGameMaker",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
